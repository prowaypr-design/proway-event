{
  "headers": [
    {
      "source": "/(.*).woff2",
      "headers": [
        {
          "key": "Content-Type",
          "value": "font/woff2"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/vendor",
      "destination": "/vendor.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/live-admin",
      "destination": "/admin.html"
    },
    {
      "source": "/live",
      "destination": "/live.html"
    },
    {
      "source": "/profile-scan",
      "destination": "/profile-scan.html"
    },
    {
      "source": "/poll",
      "destination": "/poll.html"
    },
    {
      "source": "/((?!vendor|admin|live-admin|live|profile-scan|poll|bangers\\.woff2|.*\\..+).*)",
      "destination": "/index.html"
    }
  ]
}
